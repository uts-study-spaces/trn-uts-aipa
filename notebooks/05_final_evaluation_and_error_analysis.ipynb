   "source": [
    "# **5. Recreate Test Predictions**\n",
    "\n",
    "We recreate the test split and run the saved models so we can inspect real successful and failed examples."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "6ab81103",
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-05-01T11:12:19.438966Z",
     "iopub.status.busy": "2026-05-01T11:12:19.438966Z",
     "iopub.status.idle": "2026-05-01T11:12:26.774487Z",
     "shell.execute_reply": "2026-05-01T11:12:26.774487Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Category test rows: 6,642\n",
      "Priority test rows: 6,642\n"
     ]
    }
   ],
   "source": [
    "# Load data, rebuild features, and recreate the held-out test split.\n",
    "raw = load_project_dataset(COMPATIBLE_DATASET_PATHS)\n",
    "frame, category_col, priority_col = build_modelling_frame(raw)\n",
    "\n",
    "_, _, category_test = make_train_validation_test_split(frame, category_col)\n",
    "_, _, priority_test = make_train_validation_test_split(frame, priority_col)\n",
    "\n",
    "category_model = joblib.load(MODELS_DIR / 'category_model.pkl')\n",
    "priority_model = joblib.load(MODELS_DIR / 'priority_model.pkl')\n",
    "\n",
    "category_predictions = category_model.predict(category_test['model_text'])\n",
    "priority_predictions = priority_model.predict(priority_test['model_text'])\n",
    "\n",
    "print(f'Category test rows: {len(category_test):,}')\n",
    "print(f'Priority test rows: {len(priority_test):,}')"
   ]
  },
